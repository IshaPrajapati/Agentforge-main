PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/agentforge
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=24h

# OpenAI (optional — falls back to rule engine if missing)
OPENAI_API_KEY=

# GitHub (optional — simulated if missing)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Notion (optional — simulated if missing)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Slack (optional — simulated if missing)
SLACK_WEBHOOK_URL=

# Gmail (optional — simulated if missing)
GMAIL_USER=
GMAIL_APP_PASSWORD=
NOTIFICATION_EMAIL=
